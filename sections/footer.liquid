{{ 'component-footer.css' | asset_url | stylesheet_tag }}

<footer id="contacto" class="footer">
  <div class="container footer-inner">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="{{ routes.root_url }}" class="footer-logo">
        MDB<span class="footer-logo-flame">.</span>
      </a>
      <p class="footer-tagline">{{ section.settings.tagline }}</p>
      <p class="footer-desc">{{ section.settings.description }}</p>
      
      <div class="footer-socials">
        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener noreferrer" class="footer-social-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        {% endif %}
        {% if section.settings.social_whatsapp != blank %}
          <a href="https://wa.me/{{ section.settings.social_whatsapp }}" target="_blank" rel="noopener noreferrer" class="footer-social-btn">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <!-- Navigation Links -->
    <div class="footer-col">
      <h4 class="footer-col-title">{{ section.settings.nav_title }}</h4>
      <ul class="footer-col-links">
        {% for link in linklists[section.settings.menu].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="footer-col">
      <h4 class="footer-col-title">{{ section.settings.contact_title }}</h4>
      <ul class="footer-col-info">
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          <a href="https://wa.me/{{ section.settings.social_whatsapp }}" target="_blank" rel="noopener noreferrer">WhatsApp Comercial</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener noreferrer">@mayoristadebebidas</a>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <span>Buenos Aires, Argentina</span>
        </li>
        <li>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          <span>Entregas en 24hs hábiles</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} MDB — Mayorista de Bebidas. Todos los derechos reservados.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Eslogan",
      "default": "Mayorista de Bebidas"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Distribución directa para comercios, bares y restaurantes en Buenos Aires. Logística propia · Entregas en 24hs."
    },
    {
      "type": "text",
      "id": "social_whatsapp",
      "label": "Número de WhatsApp",
      "default": "541158771523",
      "info": "Incluye el código de país sin el símbolo +"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Link de Instagram"
    },
    {
      "type": "text",
      "id": "nav_title",
      "label": "Título de Columna de Navegación",
      "default": "Navegación"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "footer",
      "label": "Menú Footer"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Título de Columna de Contacto",
      "default": "Contacto"
    }
  ]
}
{% endschema %}
