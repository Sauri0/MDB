{{ 'component-featured-collection.css' | asset_url | stylesheet_tag }}

<section id="catalogo" class="section featured-collection">
  <div class="container">
    <!-- Header -->
    <div class="catalog-header animate-on-scroll is-visible">
      <h2 class="section-title">
        {{ section.settings.title_part1 }} <span>{{ section.settings.title_part2 }}</span>
      </h2>
      <div class="divider"></div>
      <p class="catalog-subtitle">
        {{ section.settings.subtitle }}
      </p>
    </div>

    <!-- Products Slider -->
    <div class="swiper product-slider animate-on-scroll">
      <div class="swiper-wrapper">
        {%- if section.settings.collection != blank -%}
          {%- for product in section.settings.collection.products limit: section.settings.limit -%}
            <div class="swiper-slide">
              {% render 'product-card', product: product, show_vendor: true %}
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- Mockups if no collection selected -->
          {%- for i in (1..section.settings.limit) -%}
            <div class="swiper-slide">
              <div class="product-card">
                <span class="product-badge badge-premium">EJEMPLO</span>
                <div class="product-image-wrap">
                  <div class="product-image-placeholder">🍷</div>
                </div>
                <div class="product-info">
                  <span class="product-vendor uppercase">BODEGA MDB</span>
                  <span class="product-title">Vino Malbec Reserva</span>
                  <span class="product-price-logged-out">Ingresá para ver precio</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      
      <!-- Navigation -->
      <div class="slider-nav">
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.product-slider', {
      slidesPerView: 1,
      spaceBetween: 20,
      loop: false,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      breakpoints: {
        640: { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
        1200: { slidesPerView: 4 }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Catálogo Destacado",
  "settings": [
    {
      "type": "text",
      "id": "title_part1",
      "label": "Título Parte 1",
      "default": "NUESTRO"
    },
    {
      "type": "text",
      "id": "title_part2",
      "label": "Título Parte Acento",
      "default": "CATÁLOGO"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Más de 100 productos disponibles · Consultá precio por WhatsApp"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección a Mostrar"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Cantidad de productos",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Catálogo Destacado"
    }
  ]
}
{% endschema %}
