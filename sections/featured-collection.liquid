{{ 'component-featured-collection.css' | asset_url | stylesheet_tag }}

<section id="catalogo" class="section featured-collection">
  <div class="container">
    <!-- Header -->
    <div class="catalog-header animate-on-scroll is-visible">
      <h2 class="section-title">
        {{ section.settings.title_part1 }} <span>{{ section.settings.title_part2 }}</span>
      </h2>
      <div class="divider"></div>
      <p class="catalog-subtitle">
        {{ section.settings.subtitle }}
      </p>
    </div>

    <!-- Products Slider -->
    <div class="swiper product-slider animate-on-scroll">
      <div class="swiper-wrapper">
        {%- liquid
          assign target_collection = section.settings.collection
          if target_collection == blank
            assign target_collection = collections['catalogo']
          endif
        -%}

        {%- if target_collection != blank and target_collection.products_count > 0 -%}
          {%- for product in target_collection.products limit: section.settings.limit -%}
            <div class="swiper-slide">
              {% render 'product-card', product: product, show_vendor: true %}
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- Mockups if absolutely no products found -->
          {%- for i in (1..section.settings.limit) -%}
            <div class="swiper-slide">
              <div class="product-card">
                <span class="product-badge badge-premium">PRÓXIMAMENTE</span>
                <div class="product-image-wrap">
                  <div class="product-image-placeholder">🏷️</div>
                </div>
                <div class="product-info">
                  <span class="product-vendor uppercase">MDB INDUSTRIAL</span>
                  <span class="product-title">Producto en Carga</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      
      <!-- Navigation -->
      <div class="slider-nav">
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<style>
  /* Fail-safe for Slider: Ensure horizontal even if JS fails */
  .product-slider .swiper-wrapper {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
  }
</style>

<script>
  (function() {
    function initMDBFeaturedSlider() {
      const sliderEl = document.querySelector('.product-slider');
      if (!sliderEl) return;
      
      if (typeof Swiper === 'undefined') {
        console.warn('MDB: Swiper not found, retrying in 500ms...');
        setTimeout(initMDBFeaturedSlider, 500);
        return;
      }

      new Swiper('.product-slider', {
        slidesPerView: 1.2,
        spaceBetween: 20,
        loop: true,
        loopedSlides: 8,
        loopAdditionalSlides: 5,
        centeredSlides: true,
        grabCursor: true,
        speed: 1000,
        watchSlidesProgress: true,
        freeMode: {
          enabled: true,
          sticky: true,
          momentumRatio: 0.5,
        },
        autoplay: {
          delay: 4000,
          disableOnInteraction: false,
        },
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        breakpoints: {
          640: { slidesPerView: 2.2, spaceBetween: 30 },
          1024: { slidesPerView: 3.5, spaceBetween: 40 },
          1440: { slidesPerView: 4.5, spaceBetween: 50 }
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMDBFeaturedSlider);
    } else {
      initMDBFeaturedSlider();
    }
  })();
</script>

{% schema %}
{
  "name": "Catálogo Destacado",
  "settings": [
    {
      "type": "text",
      "id": "title_part1",
      "label": "Título Parte 1",
      "default": "NUESTRO"
    },
    {
      "type": "text",
      "id": "title_part2",
      "label": "Título Parte Acento",
      "default": "CATÁLOGO"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Más de 100 productos disponibles · Consultá precio por WhatsApp"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección a Mostrar"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Cantidad de productos",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Catálogo Destacado"
    }
  ]
}
{% endschema %}
