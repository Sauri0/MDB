{{ 'component-product-card.css' | asset_url | stylesheet_tag }}

<section id="catalogo-completo" class="section collection-main" data-section-id="{{ section.id }}">
  <!-- Mobile Filter Opener -->
  <div class="mobile-filters-bar container">
    <button class="btn-filters-open js-open-filters">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
      FILTRAR POR CATEGORÍA
    </button>
  </div>

  <div class="container">
    <header class="collection-header animate-on-scroll">
      <h1 class="section-title">
        {%- if collection.handle == 'all' -%}
          NUESTRO <span>CATÁLOGO</span>
        {%- else -%}
          CATEGORÍA: <span>{{ collection.title | escape }}</span>
        {%- endif -%}
      </h1>
      <div class="divider"></div>
    </header>

    <div class="collection-layout">
      <!-- Desktop Sidebar -->
      <aside class="collection-sidebar">
        <div class="sidebar-inner animate-on-scroll">
          <div class="filter-group">
            <h3 class="filter-title">BEBIDAS</h3>
            <ul class="filter-list">
              <li>
                <a href="/collections/all" class="{% if collection.handle == 'all' %}active{% endif %}">
                  <span>Todos los productos</span>
                </a>
              </li>
              {%- for product_type in shop.types -%}
                {%- if product_type != blank -%}
                  {%- assign type_url = product_type | url_for_type -%}
                  <li>
                    <a href="{{ type_url }}" class="{% if collection.current_type == product_type %}active{% endif %}">
                      <span>{{ product_type }}</span>
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

          <div class="filter-group industrial-banner">
            <h3 class="filter-title">B2B EXPRESS</h3>
            <p>Soporte mayorista inmediato vía WhatsApp.</p>
            <a href="https://wa.me/5491100000000" class="btn-sidebar-wa">
              HABLAR CON ASESOR
            </a>
          </div>
        </div>
      </aside>

      <!-- Grid Wrap -->
      <div class="collection-grid-wrap" id="CollectionSection">
        <div class="collection-grid" id="ProductGrid">
          {%- liquid
             assign items_per_page = 40
          -%}

          {%- paginate collection.products by items_per_page -%}
            {%- if collection.products.size > 0 -%}
              {%- for product in collection.products -%}
                <div class="product-grid-item">
                  {% render 'product-card', product: product, show_vendor: true %}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="collection-empty">
                <span class="empty-emoji">🔍</span>
                <p>No encontramos bultos disponibles en esta categoría.</p>
                <a href="/collections/all" class="btn-primary">VER TODO EL CATÁLOGO</a>
              </div>
            {%- endif -%}

            {%- if paginate.pages > 1 -%}
              <div class="pagination">
                {{ paginate | default_pagination: next: '>', previous: '<' }}
              </div>
            {%- endif -%}
          {%- endpaginate -%}
        </div>

        <div class="catalog-loading-overlay">
          <div class="loading-spinner"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Filter Drawer -->
  <div id="FilterDrawer" class="filter-drawer">
    <div class="filter-drawer-overlay"></div>
    <div class="filter-drawer-content">
      <div class="filter-drawer-header">
        <h3>FILTROS</h3>
        <button class="js-close-filters">&times;</button>
      </div>
      <div class="filter-drawer-body">
        <div class="filter-group">
          <h3 class="filter-title">CATEGORÍAS</h3>
          <ul class="filter-list">
             <li><a href="/collections/all" class="{% if collection.handle == 'all' %}active{% endif %}">Todos los productos</a></li>
             {%- for product_type in shop.types -%}
               {%- if product_type != blank -%}
                 <li><a href="{{ product_type | url_for_type }}">{{ product_type }}</a></li>
               {%- endif -%}
             {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.collection-main { padding: 100px 0 80px; background: #080808; position: relative; }
.collection-header { text-align: center; margin-bottom: 50px; }

/* Desktop Sidebar */
.collection-layout { display: grid; grid-template-columns: 260px 1fr; gap: 40px; }
.sidebar-inner { position: sticky; top: 120px; background: #111; border: 1px solid rgba(255,255,255,0.05); border-radius: var(--radius-lg); padding: 25px; }
.filter-title { font-family: var(--font-heading); font-size: 0.7rem; letter-spacing: 3px; color: var(--color-primary); margin-bottom: 20px; text-transform: uppercase; border-left: 2px solid var(--color-primary); padding-left: 12px; }
.filter-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 2px; }
.filter-list a { display: flex; justify-content: space-between; align-items: center; color: rgba(255,255,255,0.4); font-size: 0.85rem; padding: 10px 12px; border-radius: 4px; transition: all 0.2s ease; text-decoration: none; font-family: var(--font-heading); text-transform: uppercase; letter-spacing: 1px; }
.filter-list a:hover { background: rgba(255,255,255,0.03); color: #fff; }
.filter-list a.active { background: rgba(204,0,0,0.1); color: var(--color-primary); font-weight: 700; border-right: 2px solid var(--color-primary); }

/* Grid Layout */
#ProductGrid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 25px; min-height: 600px; }
@media (min-width: 768px) { #ProductGrid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 1200px) { #ProductGrid { grid-template-columns: repeat(4, 1fr); } }
@media (min-width: 1440px) { #ProductGrid { grid-template-columns: repeat(5, 1fr); } }

/* Industrial Empty State */
.collection-empty { grid-column: 1 / -1; text-align: center; padding: 100px 20px; border: 1px dashed rgba(255,255,255,0.1); border-radius: var(--radius-lg); }
.empty-emoji { font-size: 3rem; display: block; margin-bottom: 20px; opacity: 0.5; }
.collection-empty p { color: rgba(255,255,255,0.5); font-family: var(--font-heading); letter-spacing: 1px; margin-bottom: 30px; }

/* Filter Drawer Styles */
.filter-drawer {
  position: fixed;
  inset: 0;
  z-index: 1000;
  visibility: hidden;
  transition: all 0.3s ease;
}
.filter-drawer.is-open { visibility: visible; }
.filter-drawer-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(4px);
  opacity: 0;
  transition: opacity 0.3s ease;
}
.filter-drawer.is-open .filter-drawer-overlay { opacity: 1; }
.filter-drawer-content {
  position: absolute;
  top: 0;
  right: 0;
  width: 85%;
  max-width: 320px;
  height: 100%;
  background: #111;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  padding: 30px;
  display: flex;
  flex-direction: column;
}
.filter-drawer.is-open .filter-drawer-content { transform: translateX(0); }
.filter-drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 20px;
}
.filter-drawer-header h3 { font-family: var(--font-heading); letter-spacing: 2px; }
.js-close-filters { font-size: 2rem; line-height: 1; color: var(--color-primary); }

/* Mobile logic stays separate */
@media (max-width: 1024px) {
  .collection-layout { grid-template-columns: 1fr; }
  .collection-sidebar { display: none; }
  .mobile-filters-bar { display: block; margin-bottom: 30px; }
}

/* Desktop Fix: Force hide drawer elements that might leak */
@media (min-width: 1025px) {
  .filter-drawer { display: none !important; }
  .mobile-filters-bar { display: none !important; }
}
</style>
