<section id="catalogo-completo" class="section collection-main" data-section-id="{{ section.id }}">
  <div class="container">
    <header class="collection-header animate-on-scroll">
      <h1 class="section-title">TODOS LOS <span>PRODUCTOS</span></h1>
      <div class="divider"></div>
      {%- if collection.description != blank -%}
        <div class="collection-description">{{ collection.description }}</div>
      {%- endif -%}
    </header>

    <div class="collection-layout">
      <!-- Desktop Filters Sidebar -->
      <aside class="collection-sidebar animate-on-scroll">
        <div class="filter-group">
          <h3 class="filter-title">CATEGORÍAS</h3>
          <ul class="filter-list">
            <li><a href="/collections/all" class="{% if collection.handle == 'all' %}active{% endif %}">Todos los productos</a></li>
            {%- for product_type in shop.types -%}
              {%- if product_type != blank -%}
                <li><a href="{{ product_type | url_for_type }}" class="{% if collection.current_type == product_type %}active{% endif %}">{{ product_type }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>

        <div class="filter-group">
          <h3 class="filter-title">DISPONIBILIDAD</h3>
          <div class="filter-checkbox">
            <input type="checkbox" id="in-stock" checked disabled>
            <label for="in-stock">En Stock</label>
          </div>
        </div>
      </aside>

      <!-- Products Grid -->
      <div class="collection-grid-wrap" id="CollectionSection">
        <div class="collection-grid" id="ProductGrid">
          {%- paginate collection.products by 40 -%}
            {%- if collection.products_count > 0 -%}
              {%- for product in collection.products -%}
                <div class="product-grid-item">
                  {% render 'product-card', product: product, show_vendor: true %}
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="collection-empty">
                <span class="empty-emoji">🔍</span>
                <p>No encontramos productos en esta categoría.</p>
                <a href="/collections/all" class="btn-primary">VER TODO</a>
              </div>
            {%- endif -%}

            {%- if paginate.pages > 1 -%}
              <div class="pagination">
                {{ paginate | default_pagination }}
              </div>
            {%- endif -%}
          {%- endpaginate -%}
        </div>

        <div class="catalog-loading-overlay">
          <div class="loading-spinner"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.collection-main { padding: 120px 0 80px; }
.collection-header { text-align: center; margin-bottom: 60px; }
.collection-description { color: var(--color-text-muted); max-width: 600px; margin: 20px auto 0; font-size: 0.95rem; line-height: 1.6; }

.collection-layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 30px;
}

.collection-sidebar {
  position: sticky;
  top: 100px;
  height: fit-content;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 30px;
}

.filter-group { margin-bottom: 30px; }
.filter-group:last-child { margin-bottom: 0; }
.filter-title {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  letter-spacing: 2px;
  color: var(--color-primary);
  margin-bottom: 20px;
  text-transform: uppercase;
}

.filter-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
.filter-list a {
  color: var(--color-text-muted);
  font-size: 0.9rem;
  transition: all 0.3s ease;
  text-decoration: none;
}
.filter-list a:hover, .filter-list a.active { color: var(--color-text); padding-left: 5px; }

  /* FORCE 5 COLUMNS AND GRID BEHAVIOR */
  #ProductGrid {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 15px !important;
    width: 100% !important;
  }

  @media (min-width: 768px) {
    #ProductGrid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }

  @media (min-width: 1200px) {
    #ProductGrid {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }

  @media (min-width: 1280px) {
    #ProductGrid {
      grid-template-columns: repeat(5, 1fr) !important;
    }
  }

  /* Compact Card Adjustments */
  .product-grid-item {
    width: 100% !important;
    min-width: 0 !important;
  }

@media (min-width: 1440px) {
  .collection-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}

.collection-grid-wrap { position: relative; }
.catalog-loading-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(2px);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  z-index: 10;
}
.loading--active .catalog-loading-overlay { opacity: 1; pointer-events: auto; }
.loading-spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(255, 255, 255, 0.1);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.collection-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 100px 0;
  border: 1px dashed var(--color-border);
  border-radius: var(--radius-lg);
}
.empty-emoji { font-size: 3rem; display: block; margin-bottom: 20px; }

@media (max-width: 1024px) {
  .collection-layout { grid-template-columns: 1fr; }
  .collection-sidebar { display: none; } /* Mobile filters hidden for now or using modal */
}
</style>
