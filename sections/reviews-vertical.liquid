<section id="mdb-reviews" class="section reviews-vertical-section">
  <div class="container reviews-container">
    <div class="reviews-header animate-on-scroll">
      <h2 class="section-title">MOVIMIENTO <span>MAYORISTA</span></h2>
      <div class="divider"></div>
      <p class="section-subtitle">Lo que dicen nuestros socios estratégicos y compras recientes.</p>
    </div>

    <div class="reviews-scroller-wrap animate-on-scroll">
      <div class="reviews-track">
        {%- liquid
          # Define a combined array of mock reviews and purchases
          # Format: type, author/location, content, extra
          assign raw_mocks = "review|Juan B. (Bar Central)|MDB es nuestro aliado estratégico. Precios reales en cada pedido.|5"
          assign raw_mocks = raw_mocks | append: "##purchase|Distribuidora El Sol|compró 24 packs de Cerveza Corona 330ml|12:45hs"
          assign raw_mocks = raw_mocks | append: "##review|Sofía L. (Vinoteca SM)|La mejor logística de la zona. Nunca fallan con el stock.|5"
          assign raw_mocks = raw_mocks | append: "##purchase|Vinería San Juan|compró 12 cajas de Fernet Branca 750ml|Hace 5 min"
          assign raw_mocks = raw_mocks | append: "##review|Jorge D. (Eventos MDB)|Calidad premium y respuesta rápida por WhatsApp.|5"
          assign raw_mocks = raw_mocks | append: "##purchase|Resto Bar Palermo|compró 6 cajas de Gin Tanqueray + Tónicas|Recién"
          
          assign mocks = raw_mocks | split: "##"
        -%}

        {%- comment -%} FIRST PASS {%- endcomment -%}
        {%- for mock in mocks -%}
          {% render 'review-item', data: mock %}
        {%- endfor -%}

        {%- comment -%} SECOND PASS (FOR INFINITE LOOP) {%- endcomment -%}
        {%- for mock in mocks -%}
          {% render 'review-item', data: mock, aria_hidden: true %}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
.reviews-vertical-section {
  padding: 100px 0;
  background: #080808;
  position: relative;
  overflow: hidden;
  border-top: 1px solid rgba(255,255,255,0.05);
}

.reviews-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-subtitle {
  text-align: center;
  color: rgba(255,255,255,0.4);
  font-size: 0.9rem;
  margin-top: -10px;
  font-family: var(--font-body);
}

.reviews-scroller-wrap {
  height: 500px;
  width: 100%;
  max-width: 650px;
  position: relative;
  mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  margin-top: 50px;
}

.reviews-track {
  display: flex;
  flex-direction: column;
  gap: 24px;
  animation: scrollVertical 30s linear infinite;
  /* Disable hover pause as requested (non-controllable) */
}

@keyframes scrollVertical {
  0% { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}

.review-card {
  background: #111;
  border: 1px solid rgba(255,255,255,0.08);
  padding: 25px 35px;
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: all 0.3s ease;
}

.type-purchase {
  border-left: 3px solid var(--color-primary);
  background: linear-gradient(to right, rgba(204,0,0,0.05), transparent);
}

.review-type-badge {
  font-family: var(--font-heading);
  font-size: 0.6rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 4px;
  width: fit-content;
}

.badge-review { background: rgba(255,255,255,0.05); color: #fff; }
.badge-purchase { background: rgba(204,0,0,0.1); color: var(--color-primary); }

.review-stars {
  color: #ffcc00;
  font-size: 0.9rem;
}

.review-text {
  font-family: var(--font-body);
  font-size: 1rem;
  color: #fff;
  line-height: 1.5;
  margin: 0;
}

.purchase-content {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.review-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 5px;
}

.review-author {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1px;
}

.review-extra {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.2);
  font-style: italic;
}

.verified-tag {
  color: #25D366;
  font-weight: 700;
  margin-left: 10px;
}

@media (max-width: 768px) {
  .reviews-scroller-wrap { height: 400px; }
  .review-card { padding: 20px; }
}
</style>

{% schema %}
{
  "name": "Reseñas Verticales",
  "settings": [],
  "presets": [
    {
      "name": "Reseñas Verticales"
    }
  ]
}
{% endschema %}
