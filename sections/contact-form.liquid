{{ 'component-contact.css' | asset_url | stylesheet_tag }}

<section id="contacto" class="contact-section">
  <div class="container">
    <header class="contact-header">
      <h2 class="section-title">{{ section.settings.title_part1 }} <span>{{ section.settings.title_part2 }}</span></h2>
      <p class="contact-subtitle">{{ section.settings.subtitle }}</p>
    </header>

    <div class="contact-grid">
      <!-- Info cards -->
      <div class="contact-info">
        <div class="contact-infoCard">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 15.008 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg>
          <div>
            <h4>{{ section.settings.info_1_heading }}</h4>
            <p>{{ section.settings.info_1_text }}</p>
          </div>
        </div>
        
        <div class="contact-infoCard">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <div>
            <h4>{{ section.settings.info_2_heading }}</h4>
            <p>{{ section.settings.info_2_text }}</p>
          </div>
        </div>

        <div class="contact-infoCard">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="Mm22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          <div>
            <h4>{{ section.settings.info_3_heading }}</h4>
            <p>{{ section.settings.info_3_text }}</p>
          </div>
        </div>

        <div class="contact-infoCard">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          <div>
            <h4>{{ section.settings.info_4_heading }}</h4>
            <p>{{ section.settings.info_4_text }}</p>
          </div>
        </div>
      </div>

      <!-- Contact form wrapped in Shopify form tag -->
      <div class="contact-form-wrap">
        {% form 'contact', class: 'contact-form' %}
          {% if form.posted_successfully? %}
            <div class="contact-successMessage">
              <svg class="contact-successIcon" xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>
              <h3>¡CONSULTA RECIBIDA!</h3>
              <p>Hemos recibido tus datos correctamente. Un asesor comercial te contactará a la brevedad.</p>
            </div>
          {% else %}
            {% if form.errors %}
              <div class="contact-error">
                Revisa los errores: {{ form.errors | default_errors }}
              </div>
            {% endif %}
            
            <div class="contact-form-group">
              <input type="text" name="contact[name]" id="ContactFormName" placeholder="Nombre completo / Razón Social" required value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
            </div>
            <div class="contact-form-group">
              <input type="email" name="contact[email]" id="ContactFormEmail" placeholder="Email corporativo" autocorrect="off" autocapitalize="off" required value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
            </div>
            <div class="contact-form-group">
              <input type="tel" name="contact[phone]" id="ContactFormPhone" placeholder="Teléfono de contacto" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
            </div>
            <div class="contact-form-group">
              <textarea name="contact[body]" id="ContactFormMessage" placeholder="¿En qué podemos ayudarte? (Consulta por bultos, zonas de entrega, etc.)" required>{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>
            <button type="submit" class="contact-submitBtn">
              ENVIAR CONSULTA
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg>
            </button>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "title_part1",
      "label": "Título Principal",
      "default": "CONTACTO"
    },
    {
      "type": "text",
      "id": "title_part2",
      "label": "Título Acento",
      "default": "COMERCIAL"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Unite a nuestra red de distribución mayorista."
    },
    {
      "type": "header",
      "content": "Información Card 1"
    },
    {
      "type": "text",
      "id": "info_1_heading",
      "label": "Título",
      "default": "Ubicación Industrial"
    },
    {
      "type": "text",
      "id": "info_1_text",
      "label": "Texto",
      "default": "Av. Alvear 1234, CABA, Argentina"
    },
    {
      "type": "header",
      "content": "Información Card 2"
    },
    {
      "type": "text",
      "id": "info_2_heading",
      "label": "Título",
      "default": "Ventas Directas"
    },
    {
      "type": "text",
      "id": "info_2_text",
      "label": "Texto",
      "default": "+54 11 1234-5678"
    },
    {
      "type": "header",
      "content": "Información Card 3"
    },
    {
      "type": "text",
      "id": "info_3_heading",
      "label": "Título",
      "default": "Email Corporativo"
    },
    {
      "type": "text",
      "id": "info_3_text",
      "label": "Texto",
      "default": "ventas@mdbbebidas.com.ar"
    },
    {
      "type": "header",
      "content": "Información Card 4"
    },
    {
      "type": "text",
      "id": "info_4_heading",
      "label": "Título",
      "default": "Atención Logística"
    },
    {
      "type": "text",
      "id": "info_4_text",
      "label": "Texto",
      "default": "Lun a Vie: 08:00 - 18:00hs"
    }
  ],
  "presets": [
    {
      "name": "MDB Formulario Contacto"
    }
  ]
}
{% endschema %}
