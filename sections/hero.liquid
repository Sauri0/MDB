{{ 'component-hero.css' | asset_url | stylesheet_tag }}

<section id="inicio" class="hero">
  <!-- Background Image -->
  <div class="hero-bg-image">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.headline | escape }}">
    {% else %}
      <img src="{{ 'mdb_hero_bg.png' | asset_url }}" alt="MDB Hero">
    {% endif %}
  </div>
  
  <!-- Background overlay -->
  <div class="hero-overlay"></div>

  <!-- Content -->
  <div class="container hero-content">
    <div class="hero-text-block animate-on-scroll" style="animation-delay: 0.2s">
      <div class="hero-title-wrap">
        <h1 class="hero-headline">
          {{ section.settings.headline_part1 }} <span class="hero-headline-accent">{{ section.settings.headline_part2 }}</span>
        </h1>
        <div class="hero-tagline">{{ section.settings.tagline }}</div>
      </div>

      <div class="hero-buttons">
        <a href="{{ section.settings.catalog_link }}" class="hero-btn-catalog">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          {{ section.settings.button_catalog_label }}
        </a>
        <a href="{{ section.settings.secondary_link }}" class="hero-btn-catalog">
          {{ section.settings.button_secondary_label }}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="hero-stats animate-on-scroll" style="animation-delay: 0.6s">
      {% for block in section.blocks %}
        <div class="hero-stat-item">
          <span class="hero-stat-value">{{ block.settings.value }}</span>
          <span class="hero-stat-label">{{ block.settings.label }}</span>
          {% unless forloop.last %}
            <div class="hero-stat-divider"></div>
          {% endunless %}
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll-indicator">
    <span>SCROLL</span>
    <div class="hero-scroll-arrow"></div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "headline_part1",
      "label": "Título Principal (Parte 1)",
      "default": "MDB INDUSTRIAL"
    },
    {
      "type": "text",
      "id": "headline_part2",
      "label": "Título Principal (Parte Acento)",
      "default": "RESERVE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Eslogan / Subtítulo",
      "default": "DISTRIBUCIÓN MAYORISTA DE BEBIDAS"
    },
    {
      "type": "text",
      "id": "button_catalog_label",
      "label": "Texto Botón Catálogo",
      "default": "VER CATÁLOGO"
    },
    {
      "type": "url",
      "id": "catalog_link",
      "label": "Link Botón Catálogo"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Texto Botón Secundario",
      "default": "CONOCER MÁS"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Link Botón Secundario"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor (ej. +500)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta (ej. Clientes)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Principal",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "+500",
            "label": "Clientes Activos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "+100",
            "label": "Productos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "24hs",
            "label": "Entrega Garantizada"
          }
        }
      ]
    }
  ]
}
{% endschema %}
