{{ 'component-hero.css' | asset_url | stylesheet_tag }}

<section id="inicio" class="hero">
  <!-- Background Image -->
  <div class="hero-bg-image">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | img_url: '1920x' }}" alt="{{ section.settings.headline_part1 }}" loading="eager">
    {% else %}
      <img src="{{ 'mdb_hero_bg.png' | asset_url }}" alt="MDB Hero">
    {% endif %}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content container">
    <div class="hero-text-block">
      <span class="hero-eyebrow animate-hero" style="--d: 0.2s">DISTRIBUIDOR OFICIAL</span>
      <h1 class="hero-headline animate-hero" style="--d: 0.4s">
        {{ section.settings.headline_part1 }} <span class="hero-headline-accent">{{ section.settings.headline_part2 }}</span>
      </h1>
      <p class="hero-tagline animate-hero" style="--d: 0.6s">
        {{ section.settings.tagline }}
      </p>
    </div>

    <div class="hero-buttons animate-hero" style="--d: 0.8s">
      <a href="https://wa.me/{{ section.settings.whatsapp_number | default: '541158771523' }}?text=Hola! Me gustaría cotizar productos de MDB." target="_blank" class="hero-btn-whatsapp">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        COTIZAR PRODUCTOS
      </a>
      <a href="{{ section.settings.catalog_link | default: '/collections/all' }}" class="hero-btn-catalog">
        {{ section.settings.button_catalog_label }}
      </a>
    </div>

    <!-- Stats Row -->
    {% if section.blocks.size > 0 %}
      <div class="hero-stats animate-hero" style="--d: 1s">
        {% for block in section.blocks %}
          <div class="hero-stat-item">
            <span class="hero-stat-value">{{ block.settings.value }}</span>
            <span class="hero-stat-label">{{ block.settings.label }}</span>
          </div>
          {% unless forloop.last %}
            <div class="hero-stat-divider"></div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Scroll Down Indicator -->
  <a href="#beneficios" class="hero-scroll-indicator">
    <span>SCROLL</span>
    <div class="hero-scroll-arrow"></div>
  </a>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo(".animate-hero", 
      { opacity: 0, y: 30 },
      { 
        opacity: 1, 
        y: 0, 
        duration: 1, 
        stagger: 0.15,
        delay: 0.5,
        ease: "power2.out"
      }
    );
  });
</script>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "headline_part1",
      "label": "Título Principal (Parte 1)",
      "default": "MDB INDUSTRIAL"
    },
    {
      "type": "text",
      "id": "headline_part2",
      "label": "Título Principal (Parte Acento)",
      "default": "RESERVE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Eslogan / Subtítulo",
      "default": "DISTRIBUCIÓN MAYORISTA DE BEBIDAS"
    },
    {
      "type": "text",
      "id": "button_catalog_label",
      "label": "Texto Botón Catálogo",
      "default": "VER CATÁLOGO"
    },
    {
      "type": "url",
      "id": "catalog_link",
      "label": "Link Botón Catálogo"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Texto Botón Secundario",
      "default": "CONOCER MÁS"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Link Botón Secundario"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor (ej. +500)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta (ej. Clientes)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Principal",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "+500",
            "label": "Clientes Activos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "+100",
            "label": "Productos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "24hs",
            "label": "Entrega Garantizada"
          }
        }
      ]
    }
  ]
}
{% endschema %}
