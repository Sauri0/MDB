{{ 'component-hero.css' | asset_url | stylesheet_tag }}

<section id="inicio" class="hero">
  <!-- Background Image -->
  <div class="hero-bg-image">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | img_url: '1920x' }}" alt="{{ section.settings.headline_part1 }}" loading="eager">
    {% else %}
      <img src="{{ 'mdb_hero_bg.png' | asset_url }}" alt="MDB Hero">
    {% endif %}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content container">
    <div class="hero-text-block">
      <h1 class="hero-headline animate-hero" style="--d: 0.1s">
        {{ section.settings.headline_part1 }} <span class="hero-headline-accent">{{ section.settings.headline_part2 }}</span>
      </h1>
      
      <!-- Full Width Red Banner Bar -->
      <div class="hero-banner-bar animate-hero" style="--d: 0.3s">
        {{ section.settings.tagline }}
      </div>
    </div>

    <div class="hero-buttons animate-hero" style="--d: 0.5s">
      <a href="/collections/catalogo" class="hero-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        VER CATÁLOGO
      </a>
      <a href="#beneficios" class="hero-btn-secondary">
        CONOCER MÁS <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>

    <!-- Stats Row -->
    {% if section.blocks.size > 0 %}
      <div class="hero-stats animate-hero" style="--d: 1s">
        {% for block in section.blocks %}
          <div class="hero-stat-item">
            <span class="hero-stat-value">{{ block.settings.value }}</span>
            <span class="hero-stat-label">{{ block.settings.label }}</span>
          </div>
          {% unless forloop.last %}
            <div class="hero-stat-divider"></div>
          {% endunless %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Scroll Down Indicator -->
  <a href="#beneficios" class="hero-scroll-indicator">
    <span>SCROLL</span>
    <div class="hero-scroll-arrow"></div>
  </a>
</section>

<script>
  // Global Animation Parity (Framer Motion -> GSAP)
  document.addEventListener('DOMContentLoaded', () => {
    const tl = gsap.timeline();

    // 1. Text Block Reveal
    tl.to('.hero-text-block', {
      opacity: 1,
      y: 0,
      duration: 0.7,
      ease: 'power2.out'
    });

    // 2. Title & Tagline Reveal (Delay 0.2)
    tl.to('.hero-title-wrap', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power1.out'
    }, "-=0.5");

    // 3. Buttons Reveal (Delay 0.55)
    tl.to('.hero-buttons', {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power1.out'
    }, 0.55);

    // 4. Stats Reveal (Delay 0.7)
    tl.to('.hero-stats', {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power1.out'
    }, 0.7);

    // 5. Scroll Indicator Loop
    gsap.to('.hero-scrollIndicator', {
      y: 8,
      duration: 0.9,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
  });
</script>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "headline_part1",
      "label": "Título Principal (Parte 1)",
      "default": "MDB INDUSTRIAL"
    },
    {
      "type": "text",
      "id": "headline_part2",
      "label": "Título Principal (Parte Acento)",
      "default": "RESERVE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Eslogan / Subtítulo",
      "default": "DISTRIBUCIÓN MAYORISTA DE BEBIDAS"
    },
    {
      "type": "text",
      "id": "button_catalog_label",
      "label": "Texto Botón Catálogo",
      "default": "VER CATÁLOGO"
    },
    {
      "type": "url",
      "id": "catalog_link",
      "label": "Link Botón Catálogo"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Texto Botón Secundario",
      "default": "CONOCER MÁS"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Link Botón Secundario"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Valor (ej. +500)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta (ej. Clientes)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Principal",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "+500",
            "label": "Clientes Activos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "+100",
            "label": "Productos"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "24hs",
            "label": "Entrega Garantizada"
          }
        }
      ]
    }
  ]
}
{% endschema %}
