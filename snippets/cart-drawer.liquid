<div id="CartDrawer" class="cart-drawer">
  <div class="cart-drawer-overlay js-cart-close"></div>
  <div class="cart-drawer-inner">
    <div class="cart-drawer-header">
      <div class="cart-header-main">
        <h2 class="cart-drawer-title">TU <span>PEDIDO</span></h2>
        <button class="btn-clear-cart js-clear-cart" title="Vaciar todo el carrito">VACIAR</button>
      </div>
      <button class="cart-drawer-close js-cart-close" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div class="cart-drawer-items js-cart-items-container">
      {% comment %} Se llena via AJAX (cart-ajax.js) {% endcomment %}
      <div class="cart-drawer-empty">
        <span class="empty-icon">🛒</span>
        <p>Tu carrito está vacío</p>
        <a href="/collections/catalogo" class="btn-primary">VER CATÁLOGO</a>
      </div>
    </div>

    <div class="cart-drawer-footer js-cart-footer">
      <div class="cart-total-row">
        <span>SUBTOTAL ESTIMADO</span>
        <span class="js-cart-total-price">$0.00</span>
      </div>
      <p class="cart-tax-info">Impuestos y envío calculados al finalizar.</p>
      
      <div class="cart-actions">
        <a href="/cart" class="btn-checkout">REVISAR Y FINALIZAR COMPRA</a>
        <p class="cart-checkout-help">Podrás elegir pago con tarjeta o WhatsApp en el siguiente paso.</p>
      </div>
    </div>
  </div>
</div>

<style>
.cart-drawer {
  position: fixed;
  inset: 0;
  z-index: 2000;
  visibility: hidden;
  transition: visibility var(--transition-normal);
}

.cart-drawer.open { visibility: visible; }

.cart-drawer-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(4px);
  opacity: 0;
  transition: opacity var(--transition-normal);
}
.cart-drawer.open .cart-drawer-overlay { opacity: 1; }

.cart-drawer-inner {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  max-width: 450px;
  background: var(--color-bg);
  border-left: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.cart-drawer.open .cart-drawer-inner { transform: translateX(0); }

.cart-drawer-header {
  padding: var(--space-xl);
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--color-border);
}

.cart-drawer-title {
  font-family: var(--font-display);
  font-size: 1.5rem;
  letter-spacing: 2px;
  margin: 0;
}
.cart-drawer-title span { color: var(--color-primary); }

.cart-drawer-close {
  background: transparent;
  border: none;
  color: var(--color-text-muted);
  cursor: pointer;
  transition: color var(--transition-fast);
}
.cart-drawer-close:hover { color: var(--color-primary); }

.cart-header-main {
  display: flex;
  align-items: center;
  gap: 15px;
}

.btn-clear-cart {
  background: transparent;
  border: 1px solid rgba(255,255,255,0.1);
  color: var(--color-text-dim);
  font-size: 0.65rem;
  padding: 4px 10px;
  border-radius: 4px;
  cursor: pointer;
  letter-spacing: 1px;
  font-family: var(--font-heading);
  transition: all 0.3s ease;
}

.btn-clear-cart:hover {
  background: rgba(204,0,0,0.1);
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.cart-drawer-items {
  flex: 1;
  overflow-y: auto;
  padding: var(--space-xl);
}

.cart-item {
  display: grid;
  grid-template-columns: 80px 1fr auto;
  gap: var(--space-md);
  padding-bottom: var(--space-md);
  margin-bottom: var(--space-md);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.cart-item-image {
  width: 80px;
  height: 80px;
  background: #151515;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-item-image img { max-width: 80%; max-height: 80%; object-fit: contain; }

.cart-item-info h3 {
  font-family: var(--font-heading);
  font-size: 0.9rem;
  margin: 0 0 4px;
  color: var(--color-text);
}
.cart-item-price {
  color: var(--color-primary);
  font-family: var(--font-display);
  font-size: 1rem;
}

.cart-item-qty {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 10px;
}
.qty-btn {
  width: 24px;
  height: 24px;
  border: 1px solid var(--color-border);
  background: var(--color-surface);
  color: var(--color-text);
  border-radius: 4px;
  cursor: pointer;
}

.cart-drawer-footer {
  padding: var(--space-xl);
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}

.cart-total-row {
  display: flex;
  justify-content: space-between;
  font-family: var(--font-display);
  font-size: 1.2rem;
  margin-bottom: 8px;
}
.js-cart-total-price { color: var(--color-primary); }

.cart-tax-info {
  font-size: 0.75rem;
  color: var(--color-text-dim);
  margin-bottom: var(--space-lg);
}

.btn-checkout {
  width: 100%;
  background: white;
  color: black;
  font-family: var(--font-heading);
  font-weight: 700;
  padding: 1rem;
  border-radius: var(--radius-sm);
  letter-spacing: 2px;
  margin-bottom: 10px;
}

.btn-whatsapp-cart {
  width: 100%;
  background: var(--color-whatsapp);
  color: white;
  font-family: var(--font-heading);
  font-weight: 700;
  padding: 1rem;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
</style>
