{{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}

<!-- Backdrop -->
<div id="CartDrawerBackdrop" class="cart-drawer-backdrop" onclick="closeCartDrawer()"></div>

<!-- Drawer -->
<div id="CartDrawer" class="cart-drawer">
  <!-- Header -->
  <div class="cart-header">
    <div class="cart-header-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
      <span>Tu Pedido</span>
      <span class="cart-count js-cart-count">{{ cart.item_count }}</span>
    </div>
    <div class="cart-header-actions">
      <button class="cart-clear-btn" style="display:none;" onclick="clearCart()">Limpiar</button>
      <button class="cart-close-btn" onclick="closeCartDrawer()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <!-- Items -->
  <div class="cart-items" id="CartDrawerItems">
    <!-- El javascript renderiza los items acá o el SVG vacío -->
  </div>

  <!-- Footer CTA -->
  <div class="cart-footer" id="CartDrawerFooter" {% if cart.empty? %}style="display:none;"{% endif %}>
    <p class="cart-footer-note">Los precios se coordinan directamente con nuestro equipo.</p>
    <div class="cart-footer-buttons">
      <a href="{{ routes.cart_url }}" class="cart-view-cart-btn">VER MI CARRITO</a>
      <button class="cart-checkout-btn" onclick="window.location.href='{{ routes.cart_url }}'">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        PEDIDO WHATSAPP
      </button>
    </div>
  </div>
</div>

<!-- Floating WhatsApp button -->
<a href="https://wa.me/{{ settings.social_whatsapp | default: '541158771523' }}" target="_blank" rel="noopener noreferrer" class="floating-btn" title="Contactar por WhatsApp">
  <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
</a>

<script src="{{ 'cart-api.js' | asset_url }}" defer="defer"></script>
