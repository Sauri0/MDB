{% comment %}
  Renders a product card with high-fidelity industrial design and B2B metafields.
  Accepts:
  - product: {Object} Product object
  - show_vendor: {Boolean} Show the product vendor (optional)
{% endcomment %}

<div class="product-card animate-on-scroll">
  {%- if product.compare_at_price > product.price -%}
    <span class="product-badge badge-popular">OFERTA</span>
  {%- elsif product.tags contains 'nuevo' or product.tags contains 'Nuevo' -%}
    <span class="product-badge badge-nuevo">NUEVO</span>
  {%- elsif product.tags contains 'premium' or product.tags contains 'Premium' -%}
    <span class="product-badge badge-premium">PREMIUM</span>
  {%- endif -%}

  <div class="product-image-container js-qv-trigger" data-handle="{{ product.handle }}">
    <div class="product-image-wrap">
      {%- if product.featured_image != blank -%}
        <img 
          src="{{ product.featured_image | img_url: '800x800', scale: 2 }}" 
          alt="{{ product.title | escape }}" 
          class="product-image"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-image-placeholder' }}
      {%- endif -%}
    </div>

    <!-- Glassmorphism Specs Overlay -->
    <div class="product-card-overlay">
      <div class="product-specs-mini">
        <div class="spec-item"><span class="spec-icon">📦</span> Stock Inmediato</div>
        <div class="spec-item"><span class="spec-icon">🚚</span> Envío 24hs</div>
      </div>
  </div>

  <div class="product-info">
    {%- if show_vendor -%}
      <span class="product-vendor uppercase">{{ product.vendor }}</span>
    {%- endif -%}
    <a href="{{ product.url }}" class="product-title">{{ product.title }}</a>
    
    <div class="product-price-row">
      {% if customer %}
        <span class="product-price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="product-price-compare">{{ product.compare_at_price | money }}</span>
        {% endif %}
      {% else %}
        <span class="product-price-logged-out">Ingresá para ver precio</span>
      {% endif %}
    </div>
  </div>

  <div class="product-actions">
    {% if customer %}
      <button 
        class="btn-add-cart js-add-to-cart" 
        data-variant-id="{{ product.variants.first.id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
        AGREGAR
      </button>
    {% else %}
      <a href="https://wa.me/541158771523?text=Hola! Quiero consultar por el producto: {{ product.title }}" target="_blank" class="btn-consultar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        CONSULTAR
      </a>
    {% endif %}
  </div>
</div>
