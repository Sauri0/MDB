{% comment %}
  Renders a product card with high-fidelity industrial design and B2B metafields.
  Accepts:
  - product: {Object} Product object
  - show_vendor: {Boolean} Show the product vendor (optional)
{% endcomment %}

{%- liquid
  assign bulk_pricing = product.metafields.custom.bulk_pricing.value
  assign base_price_str = '—'
  if bulk_pricing and bulk_pricing.size > 0
    assign first_tier = bulk_pricing | first
    assign base_price_str = first_tier.price
  endif
-%}

<div class="product-card animate-on-scroll js-qv-trigger"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.variants.first.id }}"
  data-handle="{{ product.handle }}"
  data-title="{{ product.title | escape }}"
  data-vendor="{{ product.vendor | escape }}"
  data-description="{{ product.description | strip_html | truncate: 200 | escape }}"
  data-image="{{ product.featured_image | img_url: '800x800' }}"
  data-presentation="{{ product.metafields.custom.presentation | escape }}"
  data-category="{{ product.type | default: 'MDB Industrial' | escape }}"
  data-bulk='{{ bulk_pricing | json }}'
>
  {%- if product.compare_at_price > product.price -%}
    <span class="product-badge badge-popular">OFERTA</span>
  {%- elsif product.tags contains 'nuevo' or product.tags contains 'Nuevo' -%}
    <span class="product-badge badge-nuevo">NUEVO</span>
  {%- elsif product.tags contains 'premium' or product.tags contains 'Premium' -%}
    <span class="product-badge badge-premium">PREMIUM</span>
  {%- endif -%}

  <div class="product-image-container">
    <div class="product-image-wrap">
      {%- if product.featured_image != blank -%}
        <img 
          src="{{ product.featured_image | img_url: '600x600' }}" 
          alt="{{ product.title | escape }}" 
          class="product-image"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-image-placeholder' }}
      {%- endif -%}
    </div>

    <!-- Glassmorphism hover overlay -->
    <div class="product-card-overlay js-qv-trigger" data-handle="{{ product.handle }}">
      <div class="product-specs-mini">
        <div class="spec-item"><span class="spec-icon">📦</span> Stock Inmediato</div>
        <div class="spec-item"><span class="spec-icon">🚚</span> Envío 24hs</div>
        {%- if bulk_pricing and bulk_pricing.size > 0 -%}
          <div class="spec-item"><span class="spec-icon">💰</span> Escala B2B</div>
        {%- endif -%}
      </div>
      <button class="btn-quick-view js-qv-trigger" data-handle="{{ product.handle }}">VER DETALLE</button>
    </div>
  </div>

  <div class="product-info">
    {%- if show_vendor -%}
      <span class="product-vendor uppercase">{{ product.vendor }}</span>
    {%- endif -%}
    <span class="product-title">{{ product.title }}</span>
    
    <div class="product-price-row">
      {%- if bulk_pricing and bulk_pricing.size > 0 -%}
        <span class="product-price">{{ base_price_str }}</span>
      {%- elsif product.price > 0 -%}
        <span class="product-price">{{ product.price | money }}</span>
      {%- else -%}
        <span class="product-price-logged-out">Consultá precio</span>
      {%- endif -%}
    </div>
  </div>

  <div class="product-actions">
    <button class="btn-add-cart js-qv-trigger" data-handle="{{ product.handle }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
      VER DETALLE Y PRECIO
    </button>
  </div>
</div>
