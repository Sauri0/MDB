{{ 'product-quick-view.css' | asset_url | stylesheet_tag }}

<div id="mdb-quickview-backdrop" class="mdb-quickview-backdrop" aria-hidden="true"></div>

<aside id="mdb-quickview-drawer" class="mdb-quickview-drawer" role="dialog" aria-modal="true" aria-label="Detalle de Producto">
  <!-- Header -->
  <div class="mdb-qv-header">
    <span class="mdb-qv-header-title">Detalle de Producto</span>
    <button class="mdb-qv-close" id="mdb-qv-close-btn" aria-label="Cerrar">✕</button>
  </div>

  <!-- Content (populated via JS) -->
  <div class="mdb-qv-content" id="mdb-qv-content">
    <!-- Injected dynamically -->
  </div>

  <!-- Footer Actions -->
  <div class="mdb-qv-footer">
    <button class="mdb-qv-btn-cart" id="mdb-qv-add-cart">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      AGREGAR AL PEDIDO
    </button>
    <button class="mdb-qv-btn-whatsapp" id="mdb-qv-whatsapp">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/></svg>
      CONSULTAR POR WHATSAPP
    </button>
  </div>
</aside>

<script>
(function() {
  const WHATSAPP_NUMBER = '5491100000000';

  const backdrop   = document.getElementById('mdb-quickview-backdrop');
  const drawer     = document.getElementById('mdb-quickview-drawer');
  const closeBtn   = document.getElementById('mdb-qv-close-btn');
  const content    = document.getElementById('mdb-qv-content');
  const addCartBtn = document.getElementById('mdb-qv-add-cart');
  const waBtn      = document.getElementById('mdb-qv-whatsapp');

  let currentProduct = null;

  function open(product) {
    currentProduct = product;
    renderContent(product);
    backdrop.classList.add('is-open');
    drawer.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    backdrop.classList.remove('is-open');
    drawer.classList.remove('is-open');
    document.body.style.overflow = '';
    setTimeout(() => { currentProduct = null; }, 400);
  }

  function formatARS(num) {
    return '$' + Number(num).toLocaleString('es-AR');
  }

  function calcUnitPrice(qty, bulkPricing) {
    if (!bulkPricing || !bulkPricing.length) return null;
    let unit = bulkPricing[0].unitPrice;
    for (const tier of bulkPricing) {
      if (qty >= tier.minQty) unit = tier.unitPrice;
    }
    return unit;
  }

  function renderContent(product) {
    const bulkPricing = product.bulkPricing || [];

    const bulkRows = bulkPricing.length
      ? bulkPricing.map(t => `
          <div class="mdb-bulk-row">
            <span class="mdb-bulk-qty">${t.qty}</span>
            <span class="mdb-bulk-price">${t.price}</span>
          </div>`).join('')
      : `<p class="mdb-bulk-consult">Consultá escala por volumen vía WhatsApp.</p>`;

    const basePrice = bulkPricing.length ? formatARS(bulkPricing[0].unitPrice) : '—';

    content.innerHTML = `
      <div class="mdb-qv-image-block">
        ${product.image
          ? `<img src="${product.image}" alt="${product.name}" loading="eager">`
          : `<div class="mdb-qv-image-placeholder">🍾</div>`}
        ${product.badge ? `<span class="mdb-qv-badge">${product.badge}</span>` : ''}
      </div>

      <div class="mdb-qv-info">
        <span class="mdb-qv-category">${(product.category || '').toUpperCase()}</span>
        <h3 class="mdb-qv-name">${product.name}</h3>
        <p class="mdb-qv-presentation">${product.presentation || ''}</p>
        <div class="mdb-qv-status">Stock disponible</div>
      </div>

      <div class="mdb-qv-desc-block">
        <h4>Descripción</h4>
        <p>${product.description || 'Consultá para más detalles técnicos sobre este producto premium.'}</p>
      </div>

      <div class="mdb-qv-bulk-block">
        <div class="mdb-qv-bulk-header">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l-8 4v6c0 5.5 3.8 10.7 8 12 4.2-1.3 8-6.5 8-12V6l-8-4z"/></svg>
          <h4>Escala de Precios B2B</h4>
        </div>
        <div class="mdb-bulk-rows">${bulkRows}</div>
        <p class="mdb-bulk-disclaimer">* Precios sujetos a variaciones de mercado. Consultá vigencia.</p>
      </div>

      <div class="mdb-qv-qty-block">
        <label>CANTIDAD</label>
        <div class="mdb-qty-control">
          <button class="mdb-qty-btn" id="mdb-qty-minus">−</button>
          <input class="mdb-qty-input" type="number" id="mdb-qty-val" value="1" min="1" max="999">
          <button class="mdb-qty-btn" id="mdb-qty-plus">+</button>
        </div>
        <p class="mdb-qv-unit-price" id="mdb-unit-price-display">
          Precio unitario: <strong id="mdb-unit-price">${basePrice}</strong>
        </p>
      </div>
    `;

    // Qty controls
    const qtyInput = document.getElementById('mdb-qty-val');
    const unitDisplay = document.getElementById('mdb-unit-price');

    function updateUnitPrice() {
      const qty = parseInt(qtyInput.value) || 1;
      const unit = calcUnitPrice(qty, product.bulkPricing);
      if (unit && unitDisplay) unitDisplay.textContent = formatARS(unit);
    }

    document.getElementById('mdb-qty-minus').addEventListener('click', () => {
      if (parseInt(qtyInput.value) > 1) { qtyInput.value = parseInt(qtyInput.value) - 1; updateUnitPrice(); }
    });
    document.getElementById('mdb-qty-plus').addEventListener('click', () => {
      qtyInput.value = parseInt(qtyInput.value) + 1; updateUnitPrice();
    });
    qtyInput.addEventListener('input', updateUnitPrice);
  }

  // Add to cart
  addCartBtn.addEventListener('click', () => {
    if (!currentProduct) return;
    const qty = parseInt(document.getElementById('mdb-qty-val')?.value || 1);
    const unitPrice = calcUnitPrice(qty, currentProduct.bulkPricing);

    // Add to Shopify cart via AJAX
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({
        id: currentProduct.variantId,
        quantity: qty,
        properties: {
          'Precio unitario': unitPrice ? '$' + unitPrice.toLocaleString('es-AR') : '',
          'Escala aplicada': qty >= 12 ? 'Mayorista 12+' : qty >= 6 ? 'Mayorista 6+' : 'Unidad'
        }
      })
    })
    .then(r => r.json())
    .then(() => {
      addCartBtn.textContent = '✓ AGREGADO!';
      addCartBtn.style.background = '#22c55e';
      setTimeout(() => {
        addCartBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg> AGREGAR AL PEDIDO';
        addCartBtn.style.background = '';
      }, 2000);
      // Refresh cart count if available
      document.dispatchEvent(new CustomEvent('cart:refresh'));
    })
    .catch(() => {
      // Fallback: WhatsApp if cart fails
      const msg = encodeURIComponent(`Hola! Quiero pedir: ${currentProduct.name} x${qty}`);
      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${msg}`, '_blank');
    });
  });

  // WhatsApp
  waBtn.addEventListener('click', () => {
    if (!currentProduct) return;
    const qty = parseInt(document.getElementById('mdb-qty-val')?.value || 1);
    const msg = encodeURIComponent(
      `Hola! Me interesa consultar precio mayorista de:\n*${currentProduct.name}*${currentProduct.presentation ? ` (${currentProduct.presentation})` : ''}\nCantidad: ${qty} unidades`
    );
    window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${msg}`, '_blank');
  });

  backdrop.addEventListener('click', close);
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });

  // Expose globally
  window.MDBQuickView = { open, close };
})();
</script>
