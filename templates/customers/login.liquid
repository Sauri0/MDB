{{ 'component-auth.css' | asset_url | stylesheet_tag }}

<div class="auth-page">
  <div class="auth-container">
    <div class="auth-header">
      <a href="{{ routes.root_url }}" style="text-decoration:none;">
        <span style="font-family:var(--font-display);font-size:2rem;letter-spacing:3px;color:var(--color-text);">MDB<span style="color:var(--color-primary);">.</span></span>
      </a>
    </div>

    <div class="auth-content">
      <div class="auth-tabs">
        <a href="{{ routes.account_login_url }}" class="auth-tab activeTab">INGRESAR</a>
        <a href="{{ routes.account_register_url }}" class="auth-tab">CREAR CUENTA</a>
      </div>

      <h2 class="auth-title">Bienvenido de nuevo</h2>
      <p class="auth-subtitle">Accedé a tus precios exclusivos y pedidos.</p>

      {% form 'customer_login', class: 'auth-form' %}
        {% if form.errors %}
          <div class="auth-errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="auth-input-group">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          <input type="email" name="customer[email]" id="CustomerEmail" placeholder="Email corporativo" autocomplete="email" autocorrect="off" autocapitalize="off" required>
        </div>

        <div class="auth-input-group">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <input type="password" name="customer[password]" id="CustomerPassword" placeholder="Contraseña" autocomplete="current-password" required>
        </div>
        
        <button type="submit" class="auth-submit-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
          ENTRAR
        </button>
      {% endform %}
    </div>

    <div class="auth-footer">
      <p>¿Problemas con tu cuenta?</p>
      <a href="https://wa.me/541158771523" target="_blank" rel="noreferrer">Contactar Soporte Comercial</a>
    </div>
  </div>
</div>
