<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-event">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">

    <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    <!-- Estilos base extraídos de React (global.css) -->
    {{ 'base.css' | asset_url | stylesheet_tag }}
    
    <!-- Estilos dinámicos inyectados por secciones -->
    {% render 'css-variables' %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'mdb-pixel-perfect.css' | asset_url | stylesheet_tag }}

    <!-- GSAP Core & Plugins -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <!-- Swiper.js for Product Sliders -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    </script>
  </head>

  <body class="bg-dark-gradient template-{{ template.name }}">
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {% render 'cart-drawer' %}
    {% render 'auth-drawer' %}
    {% render 'quick-view-modal' %}

    {{ 'cart-ajax.js' | asset_url | script_tag }}
    {{ 'catalog-ajax.js' | asset_url | script_tag }}
    
    <script>
      // High-Fidelity Scroll Animation System with GSAP
      document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger);

        // Ensure elements are handleable immediately if script fails
        const animatedEls = document.querySelectorAll(".animate-on-scroll");
        
        // Initial state set via JS (if CSS fails or for better control)
        gsap.set(animatedEls, { opacity: 0, y: 30 });

        // Batch animate elements for performance and visibility
        ScrollTrigger.batch(".animate-on-scroll", {
          onEnter: batch => gsap.to(batch, {
            opacity: 1, 
            y: 0, 
            stagger: 0.1, 
            duration: 0.8, 
            ease: "power2.out",
            overwrite: true,
            clearProps: "all" // Important: clear styles after animation
          }),
          start: "top 95%",
          once: true
        });

        // Fail-safe: if elements are still invisible after 3 seconds, force them visible
        setTimeout(() => {
          gsap.to(".animate-on-scroll", { opacity: 1, y: 0, duration: 0.5, stagger: 0.05, clearProps: "all" });
        }, 3000);
      });
    </script>
  </body>
</html>
